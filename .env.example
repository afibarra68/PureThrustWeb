# Vacío = JSON estático en /public/api (gratis, sin servidor)
# Producción con Supabase/Strapi/Quarkus:
# VITE_API_BASE=https://tu-api.ejemplo.com

VITE_API_BASE=

# Formulario de preventa → bandeja (por defecto clientes@thrustpure.com vía FormSubmit)
# VITE_LAUNCH_SIGNUP_EMAIL=clientes@thrustpure.com

# Opcional — más fiable en producción (elige uno):
# Web3Forms: regístrate en https://web3forms.com con clientes@thrustpure.com
# VITE_WEB3FORMS_ACCESS_KEY=tu_access_key

# Formspree: crea un formulario con destino clientes@thrustpure.com
# VITE_FORMSPREE_FORM_ID=tu_form_id
